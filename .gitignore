# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# playwright
/test-results/
/playwright-report/
/.playwright-browsers/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase cli
supabase/.temp/

# local-only color-lab experiment (test images + venv + script + output)
/color-lab/

# local-only Flutter-app SQLite dump used as Schmincke-Norma seed source
/import/

# cursor
.cursor/

# claude code (per-developer local settings + runtime files)
.claude/

# allow committed Vercel env template
!.env.vercel.production.example

# model weights (SAM/FastSAM/etc.) — large binaries, never committed
*.pt

# CLAUDE.md — local-only agent context, must NEVER be on GitHub (per owner).
# Kept in the working tree (auto-loaded into Claude Code) but untracked.
CLAUDE.md
