# Copy to .env.vercel.production (ignored by git) and fill values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Filter service (Cloud Run) — bearer token must match the FILTER_SERVICE_TOKEN
# set on the Cloud Run service. Generate via `openssl rand -hex 32`.
FILTER_SERVICE_URL=
FILTER_SERVICE_TOKEN=

# Optional
NEXT_PUBLIC_ERROR_INGEST_URL=

# Optional — Slack incoming-webhook URL. When set, /api/errors/ingest
# fans out severity=error|warn events to Slack as a fire-and-forget
# POST. Unset → console-log only (Vercel function logs / GCP Logging).
SLACK_ALERT_WEBHOOK_URL=
